# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Egg info
*.egg-info

# Results (generated, not committed)
results/

# Raw lm-eval output (large, keep only summary JSONs)
baseline/results/correctness_raw/

# Prompts (generated but committed)
# eval/throughput/prompts.json

# Profiling artifacts
# Keep: README, summary jsons, throughput sweep results, AND torch chrome
# traces so teammates can grab them directly from GitHub instead of scp'ing
# from the server. Chrome traces are 20-30 MB each — well under GitHub's
# 100 MB per-file limit but they DO add up over time. If repo size becomes
# a problem, prune old traces or move them to git-lfs.
profiles/*
!profiles/README.md
!profiles/*.summary.json
!profiles/throughput_*.json
!profiles/torch_*.json.gz

# Server runtime artifacts
server.log
results/

weights/*