# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Egg info
*.egg-info

# Results (generated, not committed)
results/

# Raw lm-eval output (large, keep only summary JSONs)
baseline/results/correctness_raw/

# Prompts (generated but committed)
# eval/throughput/prompts.json

# Profiling artifacts (keep README + small summary jsons; drop chrome traces & raw)
profiles/*
!profiles/README.md
!profiles/*.summary.json
# Throughput sweep artifacts are also tiny and useful to commit alongside STATUS.md.
!profiles/throughput_*.json

# Server runtime artifacts
server.log
results/

weights/*